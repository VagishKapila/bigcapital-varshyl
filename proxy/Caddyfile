:80 {
	# Route API calls to the BigCapital server
	handle /api/* {
		reverse_proxy https://server-production-874d4.up.railway.app {
			header_up Host server-production-874d4.up.railway.app
			header_up X-Forwarded-Proto https
		}
	}

	# Route WebSocket connections to the server
	handle /socket/* {
		reverse_proxy https://server-production-874d4.up.railway.app {
			header_up Host server-production-874d4.up.railway.app
			header_up X-Forwarded-Proto https
		}
	}

	# Everything else goes to the BigCapital webapp
	handle {
		reverse_proxy https://webapp-production-1185.up.railway.app {
			header_up Host webapp-production-1185.up.railway.app
			header_up X-Forwarded-Proto https
		}
	}
}
