# ============================================================
# BigCapital — Varshyl Self-Hosted
# Railway Environment Variables
# ============================================================
# Copy these into Railway Dashboard → Project → Variables
# Secrets marked [GENERATE] should be filled in before deploy
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=production
BASE_URL=https://bigcapital-varshyl-production.up.railway.app
JWT_SECRET=[GENERATE: openssl rand -base64 32]

# ── Mail (use Resend SMTP or Gmail) ─────────────────────────
# Option A: Resend (recommended — already have Resend account)
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=resend
MAIL_PASSWORD=[YOUR_RESEND_API_KEY]
MAIL_FROM_NAME=Varshyl Accounting
MAIL_FROM_ADDRESS=noreply@varshyl.com

# Option B: Gmail (backup)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=[your app password]
# MAIL_FROM_NAME=BigCapital
# MAIL_FROM_ADDRESS=your@gmail.com

# ── Database (auto-injected by Railway MySQL plugin) ─────────
# These are set automatically when you add MySQL plugin:
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE
# Manual fallback if not using plugin:
# DB_HOST=mysql.railway.internal
# DB_USER=bigcapital
# DB_PASSWORD=[GENERATE: openssl rand -base64 16]
# DB_CHARSET=utf8
SYSTEM_DB_NAME=bigcapital_system
TENANT_DB_NAME_PERFIX=bigcapital_tenant_

# ── Redis (auto-injected by Railway Redis plugin) ────────────
# These are set automatically when you add Redis plugin:
# REDISHOST, REDISPORT
# Manual fallback:
# REDIS_HOST=redis.railway.internal
# REDIS_PORT=6379

# ── Sign-up Settings ─────────────────────────────────────────
SIGNUP_DISABLED=false
SIGNUP_EMAIL_CONFIRMATION=false
SIGNUP_ALLOWED_DOMAINS=
SIGNUP_ALLOWED_EMAILS=

# ── PDF Generation (Gotenberg) ───────────────────────────────
GOTENBERG_URL=http://gotenberg:3000
GOTENBERG_DOCS_URL=http://server:3000/public/

# ── Exchange Rate ────────────────────────────────────────────
EXCHANGE_RATE_SERVICE=open-exchange-rate
OPEN_EXCHANGE_RATE_APP_ID=

# ── Bank Sync / Plaid (Session 4) ────────────────────────────
BANK_FEED_ENABLED=false
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_LINK_WEBHOOK=

# ── S3 Attachments (optional) ────────────────────────────────
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_BUCKET=bigcapital-varshyl-docs
